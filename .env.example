# RelationshipOS Environment Configuration
# Copy this file to .env and update values for your environment.

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, for development):
DATABASE_URL=sqlite+aiosqlite:///./relationshipos.db

# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/relationshipos

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-this-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Application ───────────────────────────────────────────────────────────────
DEBUG=true
CORS_ORIGINS=["*"]
